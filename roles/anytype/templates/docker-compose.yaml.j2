networks:
  default:
    enable_ipv6: true

services:
  app:
    image: ghcr.io/grishy/any-sync-bundle:1.5.0-2026-07-17
    volumes:
      - ./data:/data
    environment:
      ANY_SYNC_BUNDLE_INIT_EXTERNAL_ADDRS: {{ anytype_domain }}
    ports:
      - {{ anytype_drpc_port }}:33010
      - {{ anytype_quic_port }}:33020/udp
    healthcheck:
      test:
        - CMD
        - timeout
        - 1s
        - bash
        - -c
        - </dev/tcp/localhost/33010
      interval: 60s
      timeout: 5s
      retries: 3
      start_period: 5s
      start_interval: 5s
