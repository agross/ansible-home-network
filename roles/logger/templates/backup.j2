#!/usr/bin/env bash
# vim: set ft=jinja-shell ts=2 sw=2 et:

set -euo pipefail

cd -- {{ logger_root | ansible.builtin.quote }}

target={{ logger_root | ansible.builtin.quote }}/backups

cleanup() {
  mkdir --parents -- "$target"

  printf 'Cleaning up InfluxDB backup directory.\n'
  # Directory needs to be kept because it is mounted on the InfluxDB container.
  rm -rf -- "${target:?}"/influxdb/{*,.*}

  printf 'Cleaning up Grafana backup directory.\n'
  rm -rf -- "${target:?}"/grafana
}

influxdb() {
  docker compose \
         exec \
         influxdb \
         influx backup \
                --compression=none \
                /backups
}

grafana() {
  local target={{ logger_root | ansible.builtin.quote }}/backups/grafana
  # renovate: docker=alpine/sqlite
  local sqlite_version=3.51.2

  mkdir --parents -- "$target"

  docker run \
         --rm \
         --volumes-from {{ ansible_role_name | ansible.builtin.quote }}-grafana-1 \
         "alpine/sqlite:$sqlite_version" \
         /var/lib/grafana/grafana.db \
         .dump \
    > "$target/db.sql"
}

trap cleanup ERR SIGINT SIGTERM

cleanup
influxdb
grafana
