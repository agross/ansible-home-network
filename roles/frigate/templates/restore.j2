#!/usr/bin/env bash
# vim: set ft=jinja-shell ts=2 sw=2 et:

set -euo pipefail

cd -- {{ frigate_root | ansible.builtin.quote }}

db() {
  # renovate: docker=alpine/sqlite
  local sqlite_version=3.51.2

  local temp_db="$(mktemp --directory)"

  # Restore using sqlite container.
  docker container \
         run \
         --interactive \
         --rm \
         --volume "$temp_db:/data" \
         "alpine/sqlite:$sqlite_version" \
         /data/frigate.db \
    < {{ frigate_root | ansible.builtin.quote }}/backups/db.sql

  # Copy into frigate container.
  docker compose create app
  docker compose cp \
                 "$temp_db/frigate.db" \
                 app:/config/frigate.db
}

db
