# {{ ansible_managed }}
http:
  routers:
    {% if logger_install_grafana | bool %}
    {{ ansible_role_name }}-grafana:
      entrypoints: https
      rule: Host(`grafana.{{ network.domain }}`)
      service: {{ ansible_role_name }}-grafana
    {% endif %}

    {{ ansible_role_name }}-influxdb:
      entrypoints: https
      rule: Host(`influxdb.{{ network.domain }}`)
      service: {{ ansible_role_name }}-influxdb

  services:
    {% if logger_install_grafana | bool %}
    {{ ansible_role_name }}-grafana:
      loadBalancer:
        servers:
          - url: http://{{ interfaces.lan.ip4.address }}:3000
    {% endif %}

    {{ ansible_role_name }}-influxdb:
      loadBalancer:
        servers:
          - url: http://{{ interfaces.lan.ip4.address }}:8086
