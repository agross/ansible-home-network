{
  "containerUser": "root",
  "customizations": {
    "vscode": {
      "extensions": ["redhat.ansible"]
    }
  },
  "image": "ghcr.io/ansible/community-ansible-dev-tools:v26.3.1",
  "name": "ansible-dev-container-docker",
  "postCreateCommand": [
    "dnf",
    "install",
    "--assumeyes",
    "python3-netaddr",
    "python3-passlib",
    "python3-bcrypt-4.3.0",
    "python3-jmespath"
  ],
  "updateContentCommand": "./bootstrap",
  "runArgs": [
    "--privileged",
    "--device",
    "/dev/fuse",
    "--hostname=ansible-dev-container"
  ],
  "updateRemoteUserUID": true
}
